---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL || '/';
---
<BaseLayout pageTitle="Custom Orders">
  <section class="page-hero page-hero-small">
    <div>
      <span class="eyebrow">Custom Orders</span>
      <h1>Custom 3D Printing & Prototyping</h1>
      <p>Bring your idea to life with tailored 3D printing support for small runs, prototypes, and one-off parts.</p>
    </div>
  </section>

  <section class="split-grid">
    <div>
      <h2>How it works</h2>
      <ol>
        <li><strong>Share your concept.</strong> Send sketches, models, or use case notes to start the quote.</li>
        <li><strong>Review materials.</strong> Choose from a range of filament and resin options based on strength, finish, and budget.</li>
        <li><strong>Approve & produce.</strong> Receive status updates, a proof image, and shipment planning for your custom order.</li>
      </ol>
    </div>
    <div class="info-card">
      <h3>Project details</h3>
      <p>Placeholder details: delivery, estimated lead time, sample prints, and assembly guidance.</p>
      <ul>
        <li>Material options: TODO PLA, PETG, resin, TPU</li>
        <li>Typical turnaround: TODO business days</li>
        <li>Ideal for: prototypes, hobby builds, replacement parts</li>
      </ul>
    </div>
  </section>

  <section class="lead-capture">
    <div>
      <h2>Start your custom order</h2>
      <p>Use the contact page to send your project brief. Mention size, function, and any special finish requests.</p>
      <a class="button" href={`${base}contact`}>Contact us about custom work</a>
    </div>
  </section>
</BaseLayout>
