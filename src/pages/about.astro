---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout pageTitle="About">
  <section class="page-hero page-hero-small">
    <div>
      <span class="eyebrow">About</span>
      <h1>About the Maker</h1>
      <p>Clean, modern 3D printing services with a maker mindset. Built for prototypes, custom creations, and small batch production.</p>
    </div>
  </section>

  <section class="split-grid">
    <div>
      <h2>Mission</h2>
      <p>Placeholder business mission statement. Explain your design focus, quality emphasis, or commitment to fast, reliable printing.</p>
      <p>We work with hobbyists, startups, and creators who need dependable 3D printing without the complexity of a larger production partner.</p>
    </div>
    <div class="info-card">
      <h3>Shop capabilities</h3>
      <ul>
        <li>FDM and resin printing</li>
        <li>Fine-detail prototypes</li>
        <li>Custom finishes and assemblies</li>
        <li>Consultation on print orientation and support removal</li>
      </ul>
    </div>
  </section>

  <section class="details-section">
    <h2>Why choose us?</h2>
    <div class="feature-grid">
      <article class="feature-card">
        <h3>Maker-first process</h3>
        <p>Fast communication, clear pricing, and a focus on your part’s function.</p>
      </article>
      <article class="feature-card">
        <h3>Flexible materials</h3>
        <p>Provide the material or let us recommend the best option for strength, detail, or finish.</p>
      </article>
      <article class="feature-card">
        <h3>Future-ready shop</h3>
        <p>Shop layout is designed to evolve into a full online storefront when you're ready.</p>
      </article>
    </div>
  </section>
</BaseLayout>
